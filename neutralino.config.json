{
  "applicationId": "com.oriondesk.app",
  "applicationName": "OrionDesk",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "enableServer": true,
  "enableNativeAPI": true,
  "singlePageServe": true,
  "documentRoot": "/frontend/public/dist/",
  "url": "/",
  "cli": {
    "binaryName": "oriondesk",
    "resourcesPath": "/frontend/public/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/frontend/public/static/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0",
    "distributionPath": "/dist/",
    "autoReloadExclude": ".*\\.log$",
    "frontendLibrary": {
      "projectPath": "/",
      "devCommand": "npm run dev",
      "buildCommand": "bun run frontend:build",
      "devUrl": "http://127.0.0.1:38472",
      "patchFile": "frontend/index.html",
      "waitTimeout": 30000
    }
  },
  "nativeAllowList": [
    "window.*",
    "app.*",
    "clipboard.*",
    "os.*",
    "computer.*",
    "filesystem.*",
    "dialog.*",
    "events.*",
    "storage.*",
    "debug.*"
  ],
  "modes": {
    "window": {
      "title": "OrionDesk",
      "width": 1280,
      "height": 800,
      "minWidth": 1024,
      "minHeight": 600,
      "center": true,
      "resizable": true,
      "maximize": false,
      "enableInspector": true,
      "injectClientLibrary": true,
      "injectGlobals": true,
      "useSavedState": true,
      "icon": "/static/icon.png"
    }
  }
}
