{
  "name": "oriondesk",
  "version": "1.0.0",
  "description": "Neutralino + Bun + Vue lightweight desktop template",
  "type": "module",
  "scripts": {
    "dev": "lsof -ti :17870 | xargs -r kill -9; lsof -ti :4173 | xargs -r kill -9; sleep 1; concurrently \"bun --env-file=server/.env --watch server/main.ts\" \"vite --config frontend/vite.config.js\"",
    "backend": "lsof -ti :17870 | xargs -r kill -9; sleep 1; bun --env-file=server/.env run server/main.ts",
    "backend:watch": "bun --watch server/main.ts",
    "frontend:dev": "vite --config frontend/vite.config.js",
    "frontend:build": "vite build --config frontend/vite.config.js",
    "shell": "lsof -ti :17870 | xargs -r kill -9; lsof -ti :4173 | xargs -r kill -9; sleep 1; npx @neutralinojs/neu run",
    "build:shell": "npx @neutralinojs/neu build",
    "build": "npx @neutralinojs/neu build",
    "build:frontend": "bun run frontend:build",
    "build:all": "npx @neutralinojs/neu build",
    "build:all:clean": "npx @neutralinojs/neu build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "hono": "^4.0.0",
    "pinia": "^3.0.4",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "bun-types": "^1.2.15",
    "concurrently": "^9.2.1",
    "element-plus": "^2.11.4",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^7.1.3",
    "vitest": "^4.1.1",
    "vue": "^3.5.21"
  },
  "keywords": [
    "neutralino",
    "bun",
    "vue",
    "desktop"
  ],
  "license": "MIT"
}
