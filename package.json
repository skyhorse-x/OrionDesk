{
  "name": "oriondesk",
  "version": "1.0.0",
  "private": true,
  "description": "Neutralino + Bun + Vue lightweight desktop template",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "bunx concurrently -k \"bun run --cwd server dev\" \"bun run --cwd frontend dev\"",
    "backend": "bun run --cwd server start",
    "frontend:dev": "bun run --cwd frontend dev",
    "frontend:build": "bun run --cwd frontend build",
    "build": "npx @neutralinojs/neu build",
    "shell": "npx @neutralinojs/neu run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "keywords": [
    "neutralino",
    "bun",
    "vue",
    "desktop"
  ],
  "license": "MIT"
}
